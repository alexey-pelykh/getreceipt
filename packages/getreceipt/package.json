{
  "name": "getreceipt",
  "version": "0.0.0",
  "type": "module",
  "description": "getreceipt — unofficial receipt fetcher (CLI + MCP), self-contained umbrella.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexey-pelykh/getreceipt.git",
    "directory": "packages/getreceipt"
  },
  "bugs": {
    "url": "https://github.com/alexey-pelykh/getreceipt/issues"
  },
  "homepage": "https://github.com/alexey-pelykh/getreceipt#readme",
  "bin": {
    "getreceipt": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "THIRD-PARTY-NOTICES"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && tsup",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "prepack": "cp ../../README.md . && cp ../../LICENSE . && node scripts/third-party-notices.mjs"
  },
  "dependencies": {
    "node-wreq": "catalog:"
  },
  "devDependencies": {
    "@getreceipt/cli": "workspace:^",
    "@getreceipt/core": "workspace:^",
    "@getreceipt/mcp": "workspace:^",
    "@types/node": "catalog:",
    "tsup": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "AGPL-3.0-only"
}
