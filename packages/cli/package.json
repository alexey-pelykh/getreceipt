{
  "name": "@getreceipt/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "Unofficial @getreceipt CLI library — composable command surfaces (commander).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexey-pelykh/getreceipt.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/alexey-pelykh/getreceipt/issues"
  },
  "homepage": "https://github.com/alexey-pelykh/getreceipt#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "@getreceipt/auth": "workspace:^",
    "@getreceipt/core": "workspace:^",
    "commander": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@getreceipt/testing": "workspace:^",
    "@types/node": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "AGPL-3.0-only"
}
