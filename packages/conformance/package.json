{
  "name": "@getreceipt/conformance",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Conformance suite for the workspace: contract, published-artifact, and repo/governance-posture tests, plus the structurally-fenced live-source verification harness (run via `test:e2e`).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexey-pelykh/getreceipt.git",
    "directory": "packages/conformance"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@getreceipt/auth": "workspace:^",
    "@getreceipt/cli": "workspace:^",
    "@getreceipt/core": "workspace:^",
    "@getreceipt/mcp": "workspace:^",
    "@getreceipt/testing": "workspace:^",
    "@modelcontextprotocol/sdk": "catalog:",
    "@types/node": "catalog:",
    "getreceipt": "workspace:^",
    "yaml": "catalog:"
  },
  "license": "AGPL-3.0-only"
}
