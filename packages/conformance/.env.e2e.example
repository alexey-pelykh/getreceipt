# getreceipt — live conformance e2e profile (TEMPLATE)
#
# Copy this to `.env.e2e.local` (gitignored) and fill in your values. It is loaded ONLY by the
# live run — `pnpm --filter @getreceipt/conformance test:e2e` — and never by CI. An explicit shell
# environment variable always overrides the matching line here.

# Master opt-in. Absent / empty / 0 / false ⇒ the live harness skips cleanly (never fails).
GETRECEIPT_E2E=1

# Canonical domain of the source to verify live (one source per run).
GETRECEIPT_E2E_SOURCE=grandfrais.com

# Account username / email for that source.
GETRECEIPT_E2E_USERNAME=you@example.com

# Credential REFERENCE — resolved at call-time behind the Secret fence, never stored as a value.
# Use a 1Password `op://<vault>/<item>/<field>` ref or `encrypted-file:<path>`; do NOT inline a raw secret.
GETRECEIPT_E2E_SECRET=op://Private/grandfrais/password
