# getreceipt — live conformance e2e env profile (TEMPLATE)
#
# Copy this to `.env.e2e.local` (gitignored) and fill it in. It is loaded ONLY by the live run —
# `pnpm --filter @getreceipt/conformance test:e2e` — and never by CI. An explicit shell environment
# variable always overrides the matching line here.
#
# The live run dogfoods the PRODUCT config: declare your sources in `.getreceipt.e2e.local.yaml`
# (copy `.getreceipt.e2e.example.yaml`) and the harness verifies EVERY one. This file only needs the
# master opt-in switch for that flow.

# Master opt-in. Absent / empty / 0 / false ⇒ the live harness skips cleanly (never fails).
GETRECEIPT_E2E=1

# --- Optional: pick a non-default config path or profile (the YAML source matrix is the preferred input) ---
# GETRECEIPT_E2E_CONFIG=/abs/path/to/some.getreceipt.yaml   # defaults to ./.getreceipt.e2e.local.yaml
# GETRECEIPT_E2E_PROFILE=default                            # which profile in the config to verify

# --- Optional: single-source OVERRIDE (verifies just this one source; skips the config entirely) ---
# Set ALL THREE to override. The secret stays a REFERENCE (op:// or encrypted-file:), never an inline value.
# GETRECEIPT_E2E_SOURCE=grandfrais.com
# GETRECEIPT_E2E_USERNAME=you@example.com
# GETRECEIPT_E2E_SECRET=op://Private/grandfrais/password
